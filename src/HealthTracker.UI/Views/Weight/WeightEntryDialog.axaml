<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HealthTracker.UI.ViewModels.Weight"
        x:Class="HealthTracker.UI.Views.Weight.WeightEntryDialog"
        x:DataType="vm:WeightEntryDialogViewModel"
        Title="Add weight entry"
        Width="360"
        Height="{Binding DialogHeight}"
        CanResize="False"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="24" Spacing="12">

        <TextBlock Text="Date" Foreground="#B0B0CC" FontSize="13" />
        <DatePicker SelectedDate="{Binding EntryDate}" />

        <TextBlock Text="Weight (kg)" Foreground="#B0B0CC" FontSize="13" Margin="0,8,0,0" />
        <TextBox Text="{Binding WeightKgInput}"
                 Watermark="e.g. 75.5"
                 AutomationProperties.Name="Weight in kilograms" />

        <TextBlock Text="{Binding ValidationError}"
                   Foreground="#EF4444"
                   IsVisible="{Binding ValidationError, Converter={x:Static ObjectConverters.IsNotNull}}"
                   FontSize="12" />

        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Classes="secondary"
                    Content="Cancel"
                    Command="{Binding CancelCommand}" />
            <Button Classes="accent"
                    Content="Save entry"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsSaveEnabled}" />
        </StackPanel>

    </StackPanel>
</Window>
